[user]
	name = Derek Morrison
	email = me@derek-morrison.com
[color]
	diff = auto
	status = auto
	branch = auto
[core]
	excludesfile = /Users/Derek/.gitignore_global
	autocrlf = input
[push]
	default = simple  # Opt in to the upcoming default push mode
[apply]
	whitespace = nowarn
[format]
	pretty = %C(yellow)%h%Creset %s %C(red)(%cr)%Creset
[github]
	user = dmorrison
	token = 
[difftool "sourcetree"]
	cmd = opendiff \"$LOCAL\" \"$REMOTE\"
	path = 
[mergetool "sourcetree"]
	cmd = /Applications/SourceTree.app/Contents/Resources/opendiff-w.sh \"$LOCAL\" \"$REMOTE\" -ancestor \"$BASE\" -merge \"$MERGED\"
	trustExitCode = true
